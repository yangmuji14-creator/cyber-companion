# ========== LLM API Keys ==========
# DeepSeek（推荐，便宜好用，纯文本）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI（兼容接口，多模型共用 — MiMo/豆包/百川等都走此 key）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=xxx

# 通义千问
TONGYI_API_KEY=sk-xxx

# Kimi
KIMI_API_KEY=sk-xxx

# 智谱
ZHIPU_API_KEY=xxx

# ========== 视觉降级模型（可选）==========
# 当主模型不支持图片时，用此视觉模型识别图片
# 也可在 settings.json → advanced.vision_model 中配置
# VISION_API_KEY=sk-xxx
# VISION_BASE_URL=https://api.xiaomimimo.com/v1

# 默认模型选择
SELECTED_MODEL=deepseek-chat
