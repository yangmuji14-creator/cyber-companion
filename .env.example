# ========== LLM API Keys ==========
# DeepSeek（推荐，便宜好用，纯文本）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI（兼容接口，很多国产模型也用这个格式，支持多模态图片）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=xxx

# 通义千问
TONGYI_API_KEY=sk-xxx

# Kimi
KIMI_API_KEY=sk-xxx

# 智谱
ZHIPU_API_KEY=xxx

# ========== 视觉降级模型（可选）==========
# 当主模型不支持图片时（如 DeepSeek），
# 图片识别会自动使用此视觉模型获取描述。
# 也可以在 settings.json → advanced.vision_model 中配置。
# VISION_API_KEY=sk-xxx

# 默认模型选择（deepseek / openai / gemini / qwen / kimi / zhipu）
SELECTED_MODEL=deepseek-v4-flash
